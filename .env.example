# Configuración de la aplicación Flask

# Ambiente: development, production, testing
FLASK_ENV=development

# Clave secreta para sesiones (cambiar en producción)
SECRET_KEY=tu-clave-secreta-super-segura

# Puerto de la aplicación (por defecto 8080 para compatibilidad con OpenShift)
PORT=8080

# ============================================
# Configuración de Base de Datos
# ============================================

# Usuario de la base de datos
DB_USER=admin

# Contraseña de la base de datos
DB_PASSWORD=tu_contraseña_segura

# Host de la base de datos
DB_HOST=localhost

# Puerto de la base de datos (PostgreSQL por defecto: 5432)
DB_PORT=5432

# Nombre de la base de datos
DB_NAME=todo_db

# ============================================
# Notas:
# ============================================
# - En desarrollo (FLASK_ENV=development):
#   Si no se configuran las variables DB_*, se usará SQLite automáticamente.
#
# - En producción (FLASK_ENV=production):
#   Las variables DB_USER, DB_PASSWORD y DB_NAME son obligatorias.
#   Se construye automáticamente la URL: postgresql://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME
